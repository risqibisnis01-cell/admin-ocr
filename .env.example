# Shared password required to open the workspace (8-1024 characters).
APP_PASSWORD=replace-with-a-strong-password

# OpenAI-compatible vision endpoint used after OCR.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_TIMEOUT_MS=60000

# Required only for the Google Vision OCR engine.
GOOGLE_VISION_API_KEY=
